    {
      "type": "text",
      "id": "code_text",
      "x": 975,
      "y": 265,
      "width": 260,
      "height": 155,
      "text": "for step in range(N):\n  # compute local attn\n  o_i += softmax(Q_i @ K_j^T) @ V_j\n  # rotate K,V clockwise\n  send(K_j, V_j) → GPU (i+1)%N\n  recv(K_j, V_j) ← GPU (i-1)%N",
      "originalText": "for step in range(N):\n  # compute local attn\n  o_i += softmax(Q_i @ K_j^T) @ V_j\n  # rotate K,V clockwise\n  send(K_j, V_j) → GPU (i+1)%N\n  recv(K_j, V_j) ← GPU (i-1)%N",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#22c55e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
